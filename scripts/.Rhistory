library(data.table)
library(GenomicRanges)
library(ggplot2)
slop24_bed <- "../data/Decoys/Decoys_proteincoding_slop24.bed"
psi_table <- "../reference/PSI_TABLE-hg38.tab.gz"
maxent_decoy_sh <- "../scripts/run_maxentscan_decoys.sh"
maxent_canonical_sh <- "../scripts/run_maxentscan_canonical.sh"
phastcons_sh <- "../scripts/extract_phastcons_scores.sh"
# Draft placeholder for future Python feature builder.
# This script does not need to exist yet for this draft to be useful.
distance_py <- "../scripts/add_decoy_distance_from_psi.py"
phastcons100_bw <- "../reference/hg38.phastCons100way.bw"
phastcons470_bw <- "../reference/hg38.phastCons470way.bw"
genome_fa <- "../../../reference/genomes/Gencode49/GRCh38.primary_assembly.genome.fa"
out_dir <- "../results"
dir.create(out_dir, showWarnings = FALSE, recursive = TRUE)
# Normalize script and reference paths to avoid cwd issues under WSL.
maxent_decoy_sh <- normalizePath(maxent_decoy_sh, mustWork = TRUE)
maxent_canonical_sh <- normalizePath(maxent_canonical_sh, mustWork = TRUE)
phastcons_sh <- normalizePath(phastcons_sh, mustWork = TRUE)
phastcons100_bw <- normalizePath(phastcons100_bw, mustWork = TRUE)
phastcons470_bw <- normalizePath(phastcons470_bw, mustWork = TRUE)
genome_fa <- normalizePath(genome_fa, mustWork = TRUE)
bed <- fread(
slop24_bed,
sep = "\t",
header = FALSE,
col.names = c("chr", "start", "end", "decoyID", "SpliceAI_score", "strand", "counts")
)
# Drop BED column 7 (counts); downstream analysis uses columns 1-6 only.
bed[, counts := NULL]
# Replace BED column 4 with GENE_startcoord format.
bed[, decoyID := paste0(decoyID, "_", start)]
cat("Loaded slop24 BED rows:", nrow(bed), "\n")
cat("Unique decoy IDs:", uniqueN(bed$decoyID), "\n")
cat("Duplicate decoyID rows:", sum(duplicated(bed$decoyID)), "\n")
psi <- fread(psi_table, sep = "\t", header = TRUE)
cat("Loaded PSI rows:", nrow(psi), "\n")
# Keep only intron events (EVENT starts with HsaIN).
psi <- psi[grepl("^HsaIN", EVENT)]
cat("Rows after EVENT filter (^HsaIN):", nrow(psi), "\n")
# Drop all quality columns ending in -Q before overlap.
q_cols <- grep("-Q$", names(psi), value = TRUE)
if (length(q_cols) > 0) {
psi[, (q_cols) := NULL]
}
cat("Dropped -Q columns:", length(q_cols), "\n")
# Parse COORD column: chr:start-end
coord_parts <- tstrsplit(psi$COORD, ":", fixed = TRUE)
range_parts <- tstrsplit(coord_parts[[2]], "-", fixed = TRUE)
psi[, chr := coord_parts[[1]]]
psi[, intron_start := as.integer(range_parts[[1]])]
psi[, intron_end := as.integer(range_parts[[2]])]
psi <- psi[!is.na(chr) & !is.na(intron_start) & !is.na(intron_end)]
cat("PSI rows with valid intron coordinates:", nrow(psi), "\n")
decoy_gr <- GRanges(
seqnames = bed$chr,
ranges = IRanges(start = bed$start + 1, end = bed$end),
strand = bed$strand
)
psi_gr <- GRanges(
seqnames = psi$chr,
ranges = IRanges(start = psi$intron_start, end = psi$intron_end)
)
hits <- findOverlaps(decoy_gr, psi_gr, ignore.strand = TRUE)
cat("Overlap pairs:", length(hits), "\n")
bed_hit <- bed[queryHits(hits)]
psi_hit <- psi[subjectHits(hits)]
# Prevent duplicate column names (e.g., chr/start/end) before binding.
overlap_cols <- intersect(names(bed_hit), names(psi_hit))
if (length(overlap_cols) > 0) {
setnames(psi_hit, overlap_cols, paste0("psi_", overlap_cols))
}
merged <- cbind(bed_hit, psi_hit)
# Keep one intron match per decoy by shortest intron length.
merged[, intron_length := intron_end - intron_start + 1L]
setorder(merged, decoyID, intron_length)
merged <- merged[!duplicated(decoyID)]
cat("Rows after shortest-intron selection:", nrow(merged), "\n")
cat("Duplicate decoyID rows after overlap selection:", sum(duplicated(merged$decoyID)), "\n")
# Reference implementation in R for now:
#   + strand: decoy_coord - intron_start
#   - strand: intron_end - decoy_coord
# Here decoy_coord is 1-based start of BED interval.
merged[, decoy_coord_1based := start + 1L]
merged[, decoy_distance_from_canonical_5ss := ifelse(
strand == "+",
decoy_coord_1based - intron_start,
intron_end - decoy_coord_1based
)]
cat("Distance calculated for rows:", sum(!is.na(merged$decoy_distance_from_canonical_5ss)), "\n")
tmp_bed_for_maxent <- file.path(out_dir, "decoy_introns_for_maxent_decoy_coords.bed")
tmp_bed_for_maxent_canonical <- file.path(out_dir, "decoy_introns_for_maxent_canonical_coords.bed")
# Decoy-site coordinates (from slop24 bed)
fwrite(
merged[, .(chr, start, end, decoyID, SpliceAI_score, strand)],
tmp_bed_for_maxent,
sep = "\t",
col.names = FALSE
)
# Canonical 5'SS coordinates (derived from intron coordinates, strand-aware)
# + strand canonical 5'SS is intron_start; - strand canonical 5'SS is intron_end.
canonical_bed <- merged[, .(
chr = chr,
start = ifelse(strand == "+", intron_start - 1L, intron_end - 1L),
end = ifelse(strand == "+", intron_start, intron_end),
decoyID = decoyID,
SpliceAI_score = SpliceAI_score,
strand = strand
)]
fwrite(canonical_bed, tmp_bed_for_maxent_canonical, sep = "\t", col.names = FALSE)
cat("Wrote temporary BED for MaxEntScan (decoy):", tmp_bed_for_maxent, "\n")
cat("Wrote temporary BED for MaxEntScan (canonical):", tmp_bed_for_maxent_canonical, "\n")
maxent_decoy_out <- file.path(out_dir, "decoy_introns_for_maxent_maxent_decoy.bed")
maxent_canonical_out <- file.path(out_dir, "decoy_introns_for_maxent_maxent_canonical.bed")
system2("bash", c(maxent_decoy_sh, tmp_bed_for_maxent, maxent_decoy_out, genome_fa))
system2("bash", c(maxent_canonical_sh, tmp_bed_for_maxent_canonical, maxent_canonical_out, genome_fa))
# Build BED of intronic segments for conservation averaging.
intron_bed_for_phastcons <- file.path(out_dir, "decoy_introns_segments.bed")
fwrite(
merged[, .(chr, intron_start - 1L, intron_end, decoyID, SpliceAI_score, strand)],
intron_bed_for_phastcons,
sep = "\t",
col.names = FALSE
)
cat("Wrote intron BED for phastCons:", intron_bed_for_phastcons, "\n")
# Script prints two columns to stdout: decoyID<TAB>mean_score.
# Capture output to files, then parse only valid tab-delimited lines.
tmp_ph470 <- tempfile(fileext = ".tsv")
tmp_ph100 <- tempfile(fileext = ".tsv")
tmp_ph470_err <- tempfile(fileext = ".err")
tmp_ph100_err <- tempfile(fileext = ".err")
status470 <- system2("bash", c(phastcons_sh, phastcons470_bw, intron_bed_for_phastcons),
stdout = tmp_ph470, stderr = tmp_ph470_err)
status100 <- system2("bash", c(phastcons_sh, phastcons100_bw, intron_bed_for_phastcons),
stdout = tmp_ph100, stderr = tmp_ph100_err)
if (status470 != 0) {
stop("phastCons 470-way command failed:\n", paste(readLines(tmp_ph470_err), collapse = "\n"))
}
View(merged)
knitr::opts_chunk$set(echo = TRUE, warning = FALSE, message = FALSE)
library(data.table)
library(GenomicRanges)
library(ggplot2)
library(VarCon)
slop24_bed <- "../data/Decoys/Decoys_proteincoding_slop24_with_phastcons.bed"
psi_table <- "../reference/PSI_TABLE-hg38.tab.gz"
genome_fa <- "../../../reference/genomes/Gencode49/GRCh38.primary_assembly.genome.fa"
out_dir <- "../results"
dir.create(out_dir, showWarnings = FALSE, recursive = TRUE)
