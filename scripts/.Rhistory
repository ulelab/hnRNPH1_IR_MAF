chr_lengths_delta <- plot_data_delta %>%
group_by(chr) %>%
summarise(max_pos = max(end, na.rm = TRUE), .groups = "drop") %>%
arrange(factor(chr, levels = chr_levels_delta))
# Calculate cumulative start positions for each chromosome
cumulative_pos_delta <- 0
chr_centers_delta <- numeric(length(chr_levels_delta))
names(chr_centers_delta) <- chr_levels_delta
plot_data_delta$cumulative_pos <- NA_real_
for (i in seq_along(chr_levels_delta)) {
chr_name <- chr_levels_delta[i]
chr_data <- plot_data_delta[plot_data_delta$chr == chr_name, ]
if (nrow(chr_data) > 0) {
chr_max_pos <- max(chr_data$end, na.rm = TRUE)
chr_centers_delta[chr_name] <- cumulative_pos_delta + chr_max_pos / 2
# Add positions for this chromosome
plot_data_delta$cumulative_pos[plot_data_delta$chr == chr_name] <-
cumulative_pos_delta + chr_data$start
cumulative_pos_delta <- cumulative_pos_delta + chr_max_pos + max(chr_lengths_delta$max_pos, na.rm = TRUE) * 0.02
}
}
# Create Manhattan plot with labels for top 100 decoys
p_manhattan_delta <- ggplot(plot_data_delta, aes(x = cumulative_pos, y = MaxEnt_delta, color = chr)) +
geom_point(alpha = 0.6, size = 0.5) +
geom_hline(yintercept = 0, linetype = "dashed", color = "gray50", alpha = 0.7) +
geom_text_repel(
aes(label = decoyID),
size = 2.5,
box.padding = unit(0.35, "lines"),
point.padding = unit(0.3, "lines"),
segment.color = 'grey50',
min.segment.length = 0,
max.overlaps = Inf
) +
scale_color_manual(values = rep(c("#1f77b4", "#ff7f0e"), length.out = length(chr_levels_delta))) +
scale_x_continuous(
breaks = chr_centers_delta,
labels = names(chr_centers_delta),
expand = expansion(mult = 0.01)
) +
labs(
title = "Manhattan Plot: MaxEntScan Delta Score (Decoy - Canonical) Across Genome (Top 100 phastCons Decoys)",
subtitle = paste("Total decoy sites plotted:", nrow(plot_data_delta)),
x = "Chromosome",
y = "MaxEntScan Delta Score (Decoy - Canonical)",
color = "Chromosome"
) +
theme_minimal() +
theme(
plot.title = element_text(size = 14, face = "bold"),
plot.subtitle = element_text(size = 12),
axis.text.x = element_text(angle = 45, hjust = 1, size = 8),
axis.text.y = element_text(size = 10),
legend.position = "none",
panel.grid.major.x = element_blank(),
panel.grid.minor.x = element_blank(),
panel.grid.minor.y = element_blank()
)
print(p_manhattan_delta)
# Print summary statistics
cat("\n=== Manhattan Plot Summary (MaxEntScan Delta) ===\n")
cat("  Total points plotted:", nrow(plot_data_delta), "\n")
cat("  Chromosomes:", length(chr_levels_delta), "\n")
cat("  MaxEnt_delta range:", round(min(plot_data_delta$MaxEnt_delta, na.rm = TRUE), 4), "-",
round(max(plot_data_delta$MaxEnt_delta, na.rm = TRUE), 4), "\n")
cat("  MaxEnt_delta mean:", round(mean(plot_data_delta$MaxEnt_delta, na.rm = TRUE), 4), "\n")
cat("  Positive delta (decoy > canonical):", sum(plot_data_delta$MaxEnt_delta > 0, na.rm = TRUE), "\n")
cat("  Negative delta (decoy < canonical):", sum(plot_data_delta$MaxEnt_delta < 0, na.rm = TRUE), "\n")
# Get top 100 decoys from phastCons analysis (if available)
