slice_head(n = 100) %>%
pull(decoyID)
top100_decoys_delta <- intersect(top100_phastcons_temp, top100_phastcons100way_temp)
}
}
# Prepare data for Manhattan plot with MaxEntScan delta score - filter to top 100 decoys only
plot_data_delta <- final_data %>%
filter(!is.na(MaxEnt_decoy) & !is.na(MaxEnt_canonical)) %>%
{ if (!is.null(top100_decoys_delta) && length(top100_decoys_delta) > 0) filter(., decoyID %in% top100_decoys_delta) else . } %>%
mutate(MaxEnt_delta = MaxEnt_decoy - MaxEnt_canonical) %>%
select(chr, start, end, MaxEnt_delta, decoyID)
# Order chromosomes (standard order + any non-standard)
chr_order <- c(paste0("chr", c(1:22, "X", "Y", "M")))
chr_levels_delta <- unique(plot_data_delta$chr)
chr_levels_delta <- c(intersect(chr_order, chr_levels_delta), setdiff(chr_levels_delta, chr_order))
plot_data_delta$chr <- factor(plot_data_delta$chr, levels = chr_levels_delta)
# Sort by chromosome and position
