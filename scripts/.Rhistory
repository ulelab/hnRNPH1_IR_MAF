start = ifelse(strand == "+", intron_start - 1L, intron_end - 1L),
end = ifelse(strand == "+", intron_start, intron_end),
decoyID = decoyID,
SpliceAI_score = SpliceAI_score,
strand = strand
)]
fwrite(canonical_bed, tmp_bed_for_maxent_canonical, sep = "\t", col.names = FALSE)
cat("Wrote temporary BED for MaxEntScan (decoy):", tmp_bed_for_maxent, "\n")
cat("Wrote temporary BED for MaxEntScan (canonical):", tmp_bed_for_maxent_canonical, "\n")
maxent_decoy_out <- file.path(out_dir, "decoy_introns_for_maxent_maxent_decoy.bed")
maxent_canonical_out <- file.path(out_dir, "decoy_introns_for_maxent_maxent_canonical.bed")
system2("bash", c(maxent_decoy_sh, tmp_bed_for_maxent, maxent_decoy_out, genome_fa))
system2("bash", c(maxent_canonical_sh, tmp_bed_for_maxent_canonical, maxent_canonical_out, genome_fa))
# Build BED of intronic segments for conservation averaging.
intron_bed_for_phastcons <- file.path(out_dir, "decoy_introns_segments.bed")
fwrite(
merged[, .(chr, intron_start - 1L, intron_end, decoyID, SpliceAI_score, strand)],
intron_bed_for_phastcons,
sep = "\t",
col.names = FALSE
)
cat("Wrote intron BED for phastCons:", intron_bed_for_phastcons, "\n")
# Script prints two columns to stdout: decoyID and mean score.
ph470_lines <- system2("bash", c(phastcons_sh, phastcons470_bw, intron_bed_for_phastcons), stdout = TRUE)
ph100_lines <- system2("bash", c(phastcons_sh, phastcons100_bw, intron_bed_for_phastcons), stdout = TRUE)
ph470 <- fread(text = paste(ph470_lines, collapse = "\n"), sep = "\t",
col.names = c("decoyID", "phastCons470_mean"))
